# Supabase — required by all skills and the MCP server
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Slack — required by executeSlackNotify
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# PagerDuty — required by escalateToPagerDuty
PAGERDUTY_API_KEY=your-pagerduty-api-key
PAGERDUTY_SERVICE_ID=your-service-id

# Redis — required by RedisCache (Phase 4)
REDIS_HOST=localhost
REDIS_PORT=6379

# Jaeger — required by DistributedTracer (Phase 4)
JAEGER_ENDPOINT=http://localhost:14268
